{
  "name": "prompter-svelte",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "npm-run-all -p dev:vite dev:electron",
    "dev:vite": "vite",
    "dev:electron": "electron . --dev",
    "build": "vite build",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.prompter.app",
    "productName": "SourceFlow",
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.0.0",
    "animate.css": "^4.1.1",
    "csso": "^5.0.5",
    "html-minifier-terser": "^7.0.0",
    "svelte-routing": "^2.13.0",
    "terser": "^5.14.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "npm-run-all": "^4.1.5",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
